{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Rusty Samplers",
  "version": "0.9.0",
  "identifier": "com.rustysamplers.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rusty Samplers",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}